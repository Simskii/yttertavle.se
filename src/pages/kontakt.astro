---
import PageLayout from '../layouts/PageLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<PageLayout title="Kontakt" description="Kontakta Yttertavle Bygdegårdsförening. Hitta oss på kartan eller hör av dig via telefon eller e-post.">
  <PageHeader title="Kontakt" subtitle="Hör av dig till oss" />

  <section class="py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div>
          <h2 class="font-heading text-2xl font-bold text-gray-900 mb-6">Kontaktuppgifter</h2>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-brand-50 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900 mb-1">Adress</p>
                <p class="text-gray-600">Bygdegårdsvägen 1<br />902 85 Yttertavle</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-brand-50 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900 mb-1">Telefon</p>
                <p class="text-gray-600">
                  <a href="tel:090-1234567" class="hover:text-brand-700 transition-colors">090-123 45 67</a>
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-brand-50 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900 mb-1">E-post</p>
                <p class="text-gray-600">
                  <a href="mailto:info@yttertavle.se" class="hover:text-brand-700 transition-colors">info@yttertavle.se</a>
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-brand-50 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900 mb-1">Uthyrning av lokalen</p>
                <p class="text-gray-600">
                  <a href="tel:070-6484804" class="hover:text-brand-700 transition-colors">070-648 48 04</a>
                </p>
              </div>
            </div>
          </div>

          <div class="mt-8">
            <a
              href="mailto:info@yttertavle.se?subject=Kontakt via yttertavle.se"
              class="inline-block px-6 py-3 bg-brand-700 text-white font-semibold rounded-full hover:bg-brand-800 transition-colors"
            >
              Skicka e-post
            </a>
          </div>
        </div>

        <div>
          <h3 class="font-bold text-gray-900 mb-3">Hitta hit</h3>
          <div class="rounded-xl overflow-hidden shadow-md">
            <iframe
              src="https://www.openstreetmap.org/export/embed.html?bbox=20.30%2C63.75%2C20.45%2C63.82&layer=mapnik&marker=63.78%2C20.38"
              class="w-full h-80 border-0"
              loading="lazy"
              title="Karta till Yttertavle Bygdegård"
            ></iframe>
          </div>
          <p class="text-gray-500 text-sm mt-3">
            Yttertavle är en by belägen cirka 3 kilometer sydost om Tomtebo.
          </p>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
