---
import PageLayout from '../layouts/PageLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<PageLayout title="Om föreningen" description="Information om Yttertavle Bygdegårdsförening för Yttertavle och Holmsjön.">
  <PageHeader title="Om föreningen" subtitle="Om föreningen" />

  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none">
        <h2 class="font-heading text-2xl font-bold text-gray-900 mb-4">Om föreningen</h2>
        <p class="text-gray-600 leading-relaxed mb-6">
          Här finner du information om Bygdegårdsföreningen för Yttertavle och Holmsjön.
        </p>
        <p class="text-gray-600 leading-relaxed mb-6">
          Yttertavle är en by belägen cirka 3 kilometer sydost om Tomtebo. Föreningens verksamhet
          omfattar bland annat skötsel och uthyrning av bygdegården, underhåll av badplatsen i
          Holmsjön, samt fritidsaktiviteter för föreningens medlemmar.
        </p>
      </div>
    </div>
  </section>
</PageLayout>
