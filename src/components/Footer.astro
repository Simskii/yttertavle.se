---
import { url } from '../utils/base';

const links = [
  { href: url('/om-oss'), label: 'Om föreningen' },
  { href: url('/lokalen'), label: 'Lokalen' },
  { href: url('/bokningsforfragan'), label: 'Bokningsförfrågan' },
  { href: url('/kontakt'), label: 'Kontakt' },
];
---

<footer class="bg-brand-900 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="font-heading font-bold text-lg mb-4">Yttertavle Bygdegårdsförening</h3>
        <div class="space-y-2 text-brand-200 text-sm">
          <p class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:070-6484804" class="hover:text-white transition-colors">070-648 48 04</a>
          </p>
          <p class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:info@yttertavle.se" class="hover:text-white transition-colors">info@yttertavle.se</a>
          </p>
        </div>
      </div>

      <div>
        <h3 class="font-bold text-sm uppercase tracking-wider mb-4">Länkar</h3>
        <ul class="space-y-2">
          {links.map((link) => (
            <li>
              <a href={link.href} class="text-brand-200 hover:text-white text-sm transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-bold text-sm uppercase tracking-wider mb-4">Bokning</h3>
        <div class="flex flex-col gap-3">
          <a
            href={url('/bokningsforfragan')}
            class="inline-flex items-center justify-center rounded-full bg-brand-700 px-5 py-2 text-sm font-semibold text-white hover:bg-brand-500 transition-colors mb-1"
          >
            Boka lokalen
          </a>
          <a
            href="mailto:info@yttertavle.se?subject=Bokningsförfrågan"
            class="inline-flex items-center justify-center rounded-full border border-brand-600 px-5 py-2 text-sm font-semibold text-brand-100 hover:border-brand-400 hover:text-white transition-colors"
          >
            Skicka e-post
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-brand-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <p class="text-center text-brand-300 text-xs">
        &copy; {new Date().getFullYear()} Yttertavle Bygdegårdsförening. Alla rättigheter förbehållna.
      </p>
    </div>
  </div>
</footer>
