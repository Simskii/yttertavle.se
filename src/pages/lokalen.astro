---
import PageLayout from '../layouts/PageLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { url } from '../utils/base';

const checkIcon = `<svg class="w-5 h-5 text-brand-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>`;
---

<PageLayout title="Lokalen" description="Hyr Yttertavle Bygdegård för fest, möten och evenemang. Se kapacitet, utrustning, priser och villkor.">
  <PageHeader title="Lokalen" subtitle="Utrustning och praktisk information inför bokning" />

  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="font-heading text-2xl font-bold text-gray-900 mb-4">Om lokalen</h2>
          <p class="text-gray-600 leading-relaxed mb-6">
            Föreningens bygdegård går att hyra för föreningsträffar, festkvällar, bröllop eller
            andra aktiviteter. Lokalen rymmer upp till 50 sittande gäster och har ett fullt
            utrustat kök.
          </p>

          <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6 text-sm text-amber-800">
            <p class="font-semibold mb-1">Viktigt att veta</p>
            <ul class="space-y-1">
              <li>Du som hyr måste vara minst 25 år</li>
              <li>Ansvarig hyrestagare ska personligen vara närvarande på tillställningen</li>
            </ul>
          </div>

          <h3 class="font-bold text-lg text-gray-900 mb-3">Tillgänglighet</h3>
          <ul class="space-y-2 text-gray-600 mb-6">
            <li class="flex items-center gap-2"><Fragment set:html={checkIcon} />Handikappanpassad toalett</li>
            <li class="flex items-center gap-2"><Fragment set:html={checkIcon} />Ramp för rullstolar och barnvagnar</li>
            <li class="flex items-center gap-2"><Fragment set:html={checkIcon} />Separat toa/omklädningsrum med dusch</li>
          </ul>

          <h3 class="font-bold text-lg text-gray-900 mb-3">Allmän utrustning</h3>
          <ul class="space-y-2 text-gray-600 mb-6">
            <li class="flex items-center gap-2"><Fragment set:html={checkIcon} />Kapprum med klädhängare</li>
            <li class="flex items-center gap-2"><Fragment set:html={checkIcon} />Två toaletter vid entrén</li>
            <li class="flex items-center gap-2"><Fragment set:html={checkIcon} />Stort serveringsbord på hjul</li>
            <li class="flex items-center gap-2"><Fragment set:html={checkIcon} />Liten bardisk</li>
            <li class="flex items-center gap-2"><Fragment set:html={checkIcon} />10 fällbara bord och 50 stapelbara stolar</li>
            <li class="flex items-center gap-2"><Fragment set:html={checkIcon} />3 barnstolar</li>
            <li class="flex items-center gap-2"><Fragment set:html={checkIcon} />Utemöbler på uteplatsen</li>
            <li class="flex items-center gap-2"><Fragment set:html={checkIcon} />Städutrustning</li>
          </ul>

          <h3 class="font-bold text-lg text-gray-900 mb-3">Teknik</h3>
          <p class="text-sm text-gray-600 leading-6 mb-3">
            Tekniken passar för möten, presentationer och enklare evenemang. Stäm gärna av behov vid bokning.
          </p>
          <ul class="space-y-2 text-gray-600 mb-6">
            <li class="flex items-center gap-2"><Fragment set:html={checkIcon} />WiFi</li>
            <li class="flex items-center gap-2"><Fragment set:html={checkIcon} />Ljudsystem för musik och tal</li>
            <li class="flex items-center gap-2"><Fragment set:html={checkIcon} />Projektor för presentationer och bildvisning</li>
            <li class="flex items-center gap-2"><Fragment set:html={checkIcon} />Mikrofoner för tal och enklare evenemang</li>
          </ul>

          <h3 class="font-bold text-lg text-gray-900 mb-3">Köksutrustning</h3>
          <ul class="space-y-2 text-gray-600 mb-8">
            <li class="flex items-center gap-2"><Fragment set:html={checkIcon} />Kylskåp med frysfack</li>
            <li class="flex items-center gap-2"><Fragment set:html={checkIcon} />Diskmaskin</li>
            <li class="flex items-center gap-2"><Fragment set:html={checkIcon} />Spis med 3 plattor och ugn</li>
            <li class="flex items-center gap-2"><Fragment set:html={checkIcon} />Dubbel kaffebryggare (cafémodell)</li>
            <li class="flex items-center gap-2"><Fragment set:html={checkIcon} />Glas, koppar, tallrikar, bestick</li>
            <li class="flex items-center gap-2"><Fragment set:html={checkIcon} />Diverse köksredskap, skålar och uppläggningsfat</li>
          </ul>

          <div class="rounded-2xl border border-gray-200 bg-gray-50 p-6">
            <h3 class="font-bold text-lg text-gray-900 mb-2">Priser och villkor</h3>
            <p class="text-sm text-gray-700 leading-relaxed mb-4">
              Fullständig prislista, deposition och samtliga regler finns på sidan
              <a href={url('/priser-och-villkor')} class="font-semibold text-brand-700 hover:underline">Priser & villkor</a>.
            </p>
            <a
              href={url('/priser-och-villkor')}
              class="inline-flex items-center justify-center rounded-full bg-brand-700 px-5 py-2.5 text-sm font-semibold text-white hover:bg-brand-800 transition-colors"
            >
              Se priser & villkor
            </a>
          </div>
        </div>

        <div class="space-y-6 lg:sticky lg:top-28">
          <div class="rounded-2xl border border-brand-100 bg-brand-50 p-6">
            <h3 class="font-bold text-lg text-gray-900 mb-3">Så bokar du</h3>
            <ol class="space-y-3 text-sm text-gray-700 list-decimal pl-5">
              <li>Kontrollera datum via telefon eller e-post.</li>
              <li>Bekräfta pris och villkor för ditt upplägg.</li>
              <li>Slutför bokningen och betala deposition enligt instruktion.</li>
            </ol>
          </div>

          <div class="rounded-2xl bg-brand-900 p-6 text-center text-white shadow-md">
            <p class="font-semibold mb-2">Vill du boka?</p>
            <p class="text-sm text-brand-100 mb-4 leading-relaxed">
              Ring uthyrningsansvarig för snabbast svar eller skicka e-post.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a
                href="tel:070-6484804"
                class="inline-block px-6 py-3 bg-white text-gray-900 font-semibold rounded-full hover:bg-gray-100 transition-colors"
              >
                Ring 070-648 48 04
              </a>
              <a
                href={url('/bokningsforfragan')}
                class="inline-block px-6 py-3 border border-brand-300 text-white font-semibold rounded-full hover:bg-brand-800 transition-colors"
              >
                Så bokar du
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
