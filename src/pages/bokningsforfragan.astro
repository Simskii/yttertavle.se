---
import PageLayout from '../layouts/PageLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { url } from '../utils/base';
---

<PageLayout title="Boka lokalen" description="Så bokar du Yttertavle Bygdegård via telefon eller e-post.">
  <PageHeader title="Boka lokalen" subtitle="Så går bokningen till" />

  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gray-50 rounded-2xl p-8 md:p-10 border border-gray-200">
        <h2 class="font-heading text-2xl font-bold text-gray-900 mb-4">Så bokar du i tre steg</h2>
        <ol class="list-decimal pl-5 space-y-3 text-gray-700 leading-relaxed">
          <li>Kontakta uthyrningsansvarig och kontrollera att datumet är ledigt.</li>
          <li>Bekräfta vilken bokningstyp som gäller och gå igenom priser och villkor.</li>
          <li>Slutför bokningen och betala enligt instruktion, inklusive deposition.</li>
        </ol>

        <div class="mt-6 p-4 rounded-xl border border-brand-100 bg-brand-50 text-sm text-gray-700">
          Se fullständig prislista och regler på
          <a href={url('/priser-och-villkor')} class="font-semibold text-brand-700 hover:underline">Priser & villkor</a>.
        </div>

        <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
          <a
            href="tel:070-6484804"
            class="flex items-center justify-center gap-3 px-6 py-4 bg-white rounded-xl border border-gray-200 hover:border-brand-300 hover:shadow-sm transition-all group"
          >
            <svg class="w-5 h-5 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span class="font-semibold text-gray-900 group-hover:text-brand-700 transition-colors">Ring 070-648 48 04</span>
          </a>

          <a
            href="mailto:info@yttertavle.se?subject=Bokningsförfrågan%20-%20Yttertavle%20Bygdegård"
            class="flex items-center justify-center gap-3 px-6 py-4 bg-white rounded-xl border border-gray-200 hover:border-brand-300 hover:shadow-sm transition-all group"
          >
            <svg class="w-5 h-5 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <span class="font-semibold text-gray-900 group-hover:text-brand-700 transition-colors">Skicka e-post</span>
          </a>
        </div>

        <p class="text-gray-500 text-sm mt-6">
          Behöver du mer information om lokalen först? Se
          <a href={url('/lokalen')} class="text-brand-700 font-semibold hover:underline">lokalen och utrustningen</a>.
        </p>
      </div>
    </div>
  </section>
</PageLayout>
