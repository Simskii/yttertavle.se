---
import PageLayout from './PageLayout.astro';

interface Props {
  title: string;
  date: Date;
  author?: string;
  description?: string;
  image?: string;
  backLink: string;
  backText: string;
}

const { title, date, author, description, image, backLink, backText } = Astro.props;

const formattedDate = date.toLocaleDateString('sv-SE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<PageLayout title={title} description={description} image={image}>
  <article class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href={backLink} class="inline-flex items-center gap-1 text-brand-700 text-sm font-medium hover:text-brand-800 mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        {backText}
      </a>

      <h1 class="font-heading text-3xl md:text-4xl font-bold text-gray-900 mb-4">{title}</h1>

      <div class="flex items-center gap-3 text-sm text-gray-500 mb-8">
        <time>{formattedDate}</time>
        {author && <span>· {author}</span>}
      </div>

      {image && (
        <img src={image} alt={title} class="w-full rounded-xl mb-8 shadow-md" />
      )}

      <div class="prose prose-lg max-w-none prose-headings:font-heading prose-headings:text-gray-900 prose-a:text-brand-700 prose-a:font-semibold">
        <slot />
      </div>
    </div>
  </article>
</PageLayout>
