---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import FeatureCard from '../components/FeatureCard.astro';
import { url } from '../utils/base';

const houseIcon = `<svg class="w-7 h-7 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819" /></svg>`;
const heartIcon = `<svg class="w-7 h-7 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg>`;
const contactIcon = `<svg class="w-7 h-7 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 6.75A2.25 2.25 0 014.5 4.5h15a2.25 2.25 0 012.25 2.25v10.5A2.25 2.25 0 0119.5 19.5h-15a2.25 2.25 0 01-2.25-2.25V6.75z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m3 7.5 8.293 5.529a1.25 1.25 0 001.414 0L21 7.5" /></svg>`;
---

<PageLayout
  title="Yttertavle Bygdegård"
  description="Yttertavle Bygdegårdsförening hyr ut bygdegården för möten, fest och aktiviteter. Se priser, utrustning och bokning."
>
  <Hero
    title="Välkommen till Yttertavle Bygdegård"
    subtitle="För uthyrning, möten och aktiviteter i Yttertavle."
    ctaText="Boka nu"
    ctaLink={url('/bokningsforfragan')}
    backgroundImage="https://www.yttertavle.se/index_htm_files/26.jpg"
  />

  <section class="pt-0 pb-12 md:pb-16 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 -mt-16 relative z-20">
        <FeatureCard
          title="Hyr lokalen"
          description="Information om priser, utrustning och kontakt för bokning."
          linkText="Boka lokalen"
          linkHref={url('/lokalen')}
          icon={houseIcon}
        />
        <FeatureCard
          title="Om föreningen"
          description="Kort om föreningen och verksamheten i Yttertavle och Holmsjön."
          linkText="Läs mer om föreningen"
          linkHref={url('/om-oss')}
          icon={heartIcon}
        />
        <FeatureCard
          title="Kontakt & bokning"
          description="Ring för snabbast svar eller skicka e-post för bokningsförfrågan."
          linkText="Kontakta oss"
          linkHref={url('/kontakt')}
          icon={contactIcon}
        />
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-2xl md:text-3xl font-bold text-gray-900 mb-6">
        Om föreningen
      </h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        Här finner du information om Bygdegårdsföreningen för Yttertavle och Holmsjön.
      </p>
      <p class="text-gray-600 leading-relaxed">
        Föreningens verksamhet omfattar bland annat skötsel och uthyrning av bygdegården,
        underhåll av badplatsen i Holmsjön samt fritidsaktiviteter för medlemmar.
      </p>
      <div class="mt-8">
        <a
          href={url('/om-oss')}
          class="inline-flex items-center justify-center rounded-full bg-brand-700 px-6 py-3 font-semibold text-white hover:bg-brand-800 transition-colors"
        >
          Läs mer om föreningen
        </a>
      </div>
    </div>
  </section>
</PageLayout>
