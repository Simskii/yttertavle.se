---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getCollection } from 'astro:content';

const allEvenemang = await getCollection('evenemang', ({ data }) => !data.draft);
const sortedEvenemang = allEvenemang.sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

const now = new Date();
const upcoming = sortedEvenemang.filter((e) => e.data.date >= now);
const past = sortedEvenemang.filter((e) => e.data.date < now).reverse();
---

<PageLayout title="Evenemang" description="Kommande evenemang på Yttertavle Bygdegård.">
  <PageHeader title="Evenemang" subtitle="Vad händer i bygdegården?" />

  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      {upcoming.length > 0 && (
        <>
          <h2 class="font-heading text-2xl font-bold text-gray-900 mb-6">Kommande evenemang</h2>
          <div class="space-y-4 mb-12">
            {upcoming.map((event) => (
              <a href={`/evenemang/${event.id}`} class="block bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-6">
                <div class="flex flex-col sm:flex-row sm:items-center gap-4">
                  <div class="flex-shrink-0 w-16 h-16 bg-brand-50 rounded-lg flex flex-col items-center justify-center">
                    <span class="text-2xl font-bold text-brand-700">{event.data.date.getDate()}</span>
                    <span class="text-xs text-brand-600 uppercase">{event.data.date.toLocaleDateString('sv-SE', { month: 'short' })}</span>
                  </div>
                  <div class="flex-1">
                    <h3 class="font-bold text-lg text-gray-900">{event.data.title}</h3>
                    <p class="text-gray-500 text-sm">{event.data.time} · {event.data.location}</p>
                    <p class="text-gray-600 text-sm mt-1">{event.data.excerpt}</p>
                  </div>
                  {event.data.price && (
                    <span class="text-brand-700 font-semibold text-sm whitespace-nowrap">{event.data.price}</span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </>
      )}

      {upcoming.length === 0 && (
        <p class="text-center text-gray-500 text-lg mb-12">
          Inga kommande evenemang just nu. Håll utkik!
        </p>
      )}

      {past.length > 0 && (
        <>
          <h2 class="font-heading text-2xl font-bold text-gray-900 mb-6">Tidigare evenemang</h2>
          <div class="space-y-4 opacity-75">
            {past.map((event) => (
              <a href={`/evenemang/${event.id}`} class="block bg-gray-50 rounded-xl border border-gray-100 p-6">
                <div class="flex flex-col sm:flex-row sm:items-center gap-4">
                  <div class="flex-shrink-0 w-16 h-16 bg-gray-100 rounded-lg flex flex-col items-center justify-center">
                    <span class="text-2xl font-bold text-gray-500">{event.data.date.getDate()}</span>
                    <span class="text-xs text-gray-400 uppercase">{event.data.date.toLocaleDateString('sv-SE', { month: 'short' })}</span>
                  </div>
                  <div>
                    <h3 class="font-bold text-lg text-gray-700">{event.data.title}</h3>
                    <p class="text-gray-400 text-sm">{event.data.time} · {event.data.location}</p>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </>
      )}
    </div>
  </section>
</PageLayout>
