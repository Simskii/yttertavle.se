---
import PageLayout from '../layouts/PageLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { url } from '../utils/base';
---

<PageLayout title="Boka lokalen" description="Boka Yttertavle Bygdegård för ditt evenemang.">
  <PageHeader title="Boka lokalen" subtitle="Hör av dig för att boka" />

  <section class="py-16 md:py-24">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="bg-gray-50 rounded-2xl p-8 md:p-12">
        <div class="w-16 h-16 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </div>

        <h2 class="font-heading text-2xl font-bold text-gray-900 mb-4">
          Kontakta uthyrningsansvarig
        </h2>
        <p class="text-gray-600 mb-6 leading-relaxed">
          Vill du boka bygdegården för fest, möte, bröllop eller annan tillställning?
          Ring eller mejla så hjälper vi dig.
        </p>

        <div class="space-y-4 mb-8">
          <a
            href="tel:070-6484804"
            class="flex items-center justify-center gap-3 px-6 py-4 bg-white rounded-xl border border-gray-200 hover:border-brand-300 hover:shadow-sm transition-all group"
          >
            <svg class="w-5 h-5 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span class="font-semibold text-gray-900 group-hover:text-brand-700 transition-colors">070-648 48 04</span>
          </a>

          <a
            href="mailto:info@yttertavle.se?subject=Bokningsförfrågan%20-%20Yttertavle%20Bygdegård"
            class="flex items-center justify-center gap-3 px-6 py-4 bg-white rounded-xl border border-gray-200 hover:border-brand-300 hover:shadow-sm transition-all group"
          >
            <svg class="w-5 h-5 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <span class="font-semibold text-gray-900 group-hover:text-brand-700 transition-colors">info@yttertavle.se</span>
          </a>
        </div>

        <p class="text-gray-500 text-sm">
          Du som hyr måste vara minst 25 år. Se <a href={url('/lokalen')} class="text-brand-700 font-semibold hover:underline">priser och utrustning</a>.
        </p>
      </div>
    </div>
  </section>
</PageLayout>
