---
interface Props {
  title: string;
  date: Date;
  excerpt: string;
  image?: string;
  slug: string;
  linkLabel?: string;
}

const { title, date, excerpt, image, slug, linkLabel } = Astro.props;

const formattedDate = date.toLocaleDateString('sv-SE', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<article class="group">
  <a href={`/nyheter/${slug}`} class="block mb-4">
    {image ? (
      <div class="rounded-2xl overflow-hidden">
        <img
          src={image}
          alt={title}
          class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300"
          loading="lazy"
        />
      </div>
    ) : (
      <div class="rounded-2xl overflow-hidden">
        <div class="w-full h-48 bg-brand-50 flex items-center justify-center">
          <svg class="w-12 h-12 text-brand-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
      </div>
    )}
  </a>
  <a href={`/nyheter/${slug}`} class="block">
    <h3 class="font-bold text-base mb-1 text-gray-900 group-hover:text-brand-700 transition-colors">
      {title}
    </h3>
  </a>
  <p class="text-gray-600 text-sm leading-relaxed mb-3 line-clamp-3">{excerpt}</p>
  <div class="flex items-center gap-2 flex-wrap">
    {linkLabel && (
      <a
        href={`/nyheter/${slug}`}
        class="inline-block px-4 py-1.5 border border-gray-800 text-gray-800 text-xs font-medium rounded-full hover:bg-brand-700 hover:text-white hover:border-brand-700 transition-colors"
      >
        {linkLabel}
      </a>
    )}
    <span class="inline-block px-3 py-1 border border-gray-300 text-gray-500 text-xs rounded-full">
      {formattedDate}
    </span>
  </div>
</article>
