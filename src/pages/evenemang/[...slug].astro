---
import PostLayout from '../../layouts/PostLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const evenemang = await getCollection('evenemang', ({ data }) => !data.draft);
  return evenemang.map((event) => ({
    params: { slug: event.id },
    props: event,
  }));
}

const event = Astro.props;
const { Content } = await render(event);

const formattedDate = event.data.date.toLocaleDateString('sv-SE', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<PostLayout
  title={event.data.title}
  date={event.data.date}
  backLink="/evenemang"
  backText="Tillbaka till evenemang"
>
  <div class="bg-brand-50 rounded-xl p-6 mb-8 not-prose">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
      <div>
        <span class="font-semibold text-gray-900">Datum:</span>
        <span class="text-gray-600 ml-1">{formattedDate}</span>
      </div>
      <div>
        <span class="font-semibold text-gray-900">Tid:</span>
        <span class="text-gray-600 ml-1">{event.data.time}</span>
      </div>
      <div>
        <span class="font-semibold text-gray-900">Plats:</span>
        <span class="text-gray-600 ml-1">{event.data.location}</span>
      </div>
      {event.data.price && (
        <div>
          <span class="font-semibold text-gray-900">Pris:</span>
          <span class="text-gray-600 ml-1">{event.data.price}</span>
        </div>
      )}
    </div>
  </div>
  <Content />
</PostLayout>
