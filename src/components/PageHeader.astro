---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="relative bg-brand-700 py-16 md:py-20 overflow-hidden">
  <div class="absolute inset-0 opacity-10">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style={`background-image: url('${import.meta.env.BASE_URL}hero-background.svg')`}
    ></div>
  </div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-3">
      {title}
    </h1>
    {subtitle && (
      <p class="text-brand-200 text-lg max-w-2xl mx-auto">{subtitle}</p>
    )}
  </div>
</section>
